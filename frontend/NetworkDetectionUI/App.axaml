<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NetworkDetectionUI.App"
             xmlns:local="using:NetworkDetectionUI"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <Color x:Key="PrimaryColor">#1A237E</Color>
        <Color x:Key="PrimaryLight">#534BAE</Color>
        <Color x:Key="SurfaceColor">#1E1E2E</Color>
        <Color x:Key="CardColor">#2A2A3E</Color>
        <Color x:Key="TextPrimary">#E0E0E0</Color>
        <Color x:Key="TextSecondary">#9E9E9E</Color>
        <Color x:Key="BorderColor">#3A3A4E</Color>
        <Color x:Key="DangerColor">#E53935</Color>
        <Color x:Key="WarningColor">#FB8C00</Color>
        <Color x:Key="SuccessColor">#43A047</Color>
        <Color x:Key="InfoColor">#78909C</Color>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <Style Selector="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:hover">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
        </Style>
        <Style Selector="DataGridRow:hover">
            <Setter Property="Background" Value="#333350"/>
        </Style>

        <Style Selector="TabControl">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
        </Style>
    </Application.Styles>
</Application>
